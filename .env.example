# .env.example - Copy to .env and fill in your values

# Proxy SQLite DB path (PoolProx2 format)
CLAW_PROXY_DB=/path/to/proxy_pool.db

# Tokens output file
CLAW_TOKENS_FILE=tokens.json

# Log file
CLAW_LOG_FILE=/tmp/claw_batch.log

# Webshare proxy credentials (if not using DB)
# Format: http://user:pass@host:port
WEBSHARE_USER=your_webshare_username
WEBSHARE_PASS=your_webshare_password
